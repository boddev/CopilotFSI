{
    "$schema":  "https://aka.ms/json-schemas/copilot/plugin/v2.4/schema.json",
    "schema_version":  "v2.4",
    "name_for_human":  "Aiera",
    "namespace":  "Aiera",
    "description_for_human":  "Search corporate events and retrieve earnings call transcripts with optional sentiment analysis via Aiera.",
    "description_for_model":  "Provides access to Aiera\u0027s corporate event intelligence platform via the Aiera Events API (REST). Use this plugin to search for corporate events (earnings calls, presentations, shareholder meetings), retrieve event metadata, and get full speaker-tagged transcripts with optional NLP linguistics (sentiment, topics, summaries). Maps to Aiera REST API endpoints: GET /events-v2, GET /events-v2/{id}, GET /events-v2/{id}/transcript.",
    "functions":  [
                      {
                          "name":  "find_events",
                          "description":  "Search for corporate events (earnings calls, presentations, shareholder meetings) by company, date range, or event type via Aiera Events API.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "ticker":  {
                                                                               "type":  "string",
                                                                               "description":  "Stock ticker symbol to filter events (e.g., AAPL, MSFT)"
                                                                           },
                                                                "event_type":  {
                                                                                   "type":  "string",
                                                                                   "description":  "Type of corporate event: \u0027earnings\u0027, \u0027earnings_release\u0027, \u0027presentation\u0027, or \u0027shareholder_meeting\u0027"
                                                                               },
                                                                "start_date":  {
                                                                                   "type":  "string",
                                                                                   "description":  "Start date filter in ISO 8601 format (e.g., 2024-01-01)"
                                                                               },
                                                                "end_date":  {
                                                                                 "type":  "string",
                                                                                 "description":  "End date filter in ISO 8601 format (e.g., 2024-12-31)"
                                                                             },
                                                                "with_transcripts":  {
                                                                                         "type":  "boolean",
                                                                                         "description":  "If true, filter to only events that have transcripts available"
                                                                                     }
                                                            },
                                             "required":  [

                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "get_event_details",
                          "description":  "Retrieve full metadata for a specific corporate event including title, date, participants, and status.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "event_id":  {
                                                                                 "type":  "string",
                                                                                 "description":  "Aiera event ID for the specific corporate event"
                                                                             }
                                                            },
                                             "required":  [
                                                              "event_id"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "get_transcript",
                          "description":  "Retrieve the full speaker-tagged transcript for a corporate event, with optional sentiment analysis, topic extraction, and section tags (Q\u0026A, presentation).",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "event_id":  {
                                                                                 "type":  "string",
                                                                                 "description":  "Aiera event ID for the specific corporate event"
                                                                             },
                                                                "linguistics":  {
                                                                                    "type":  "boolean",
                                                                                    "description":  "If true, include NLP-derived sentiment scores, topic extraction, and summaries"
                                                                                },
                                                                "include_tags":  {
                                                                                     "type":  "boolean",
                                                                                     "description":  "If true, include section breakdown tags (e.g., Q\u0026A, presentation)"
                                                                                 },
                                                                "modified_since":  {
                                                                                       "type":  "string",
                                                                                       "description":  "ISO 8601 timestamp to retrieve only updates since this time (useful for live call partial updates)"
                                                                                   }
                                                            },
                                             "required":  [
                                                              "event_id"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      }
                  ],
    "runtimes":  [
                     {
                         "type":  "RemoteMCPServer",
                         "spec":  {
                                      "url":  "https://mcp-pub.aiera.com"
                                  },
                         "auth":  {
                                      "type":  "ApiKeyPluginVault"
                                  },
                         "run_for_functions":  [
                                                   "find_events",
                                                   "get_event_details",
                                                   "get_transcript"
                                               ]
                     }
                 ]
}
