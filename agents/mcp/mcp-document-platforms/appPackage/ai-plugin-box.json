{
    "$schema":  "https://aka.ms/json-schemas/copilot/plugin/v2.4/schema.json",
    "schema_version":  "v2.4",
    "name_for_human":  "Box Platform",
    "namespace":  "BoxPlatform",
    "description_for_human":  "Search, retrieve, and read documents stored in Box.",
    "description_for_model":  "Provides access to Box\u0027s cloud content management platform. Use this plugin to search for documents across Box repositories, retrieve file details and download links, list folder contents, extract text from documents, and retrieve file metadata. Essential for accessing research reports, deal documents, compliance files, and other content stored in Box.",
    "functions":  [
                      {
                          "name":  "search_documents",
                          "description":  "Search for documents in Box using full-text search with optional folder and file type filters.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "query":  {
                                                                              "type":  "string",
                                                                              "description":  "Full-text search query to find documents"
                                                                          },
                                                                "folder_id":  {
                                                                                  "type":  "string",
                                                                                  "description":  "Optional Box folder ID to scope the search to a specific folder"
                                                                              },
                                                                "file_type":  {
                                                                                  "type":  "string",
                                                                                  "description":  "Optional file type filter: \u0027pdf\u0027, \u0027docx\u0027, \u0027xlsx\u0027, \u0027pptx\u0027, or \u0027all\u0027"
                                                                              }
                                                            },
                                             "required":  [
                                                              "query",
                                                              "folder_id",
                                                              "file_type"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "get_document",
                          "description":  "Retrieve document details including name, size, owner, and download URL from Box.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "file_id":  {
                                                                                "type":  "string",
                                                                                "description":  "Box file ID of the document to retrieve"
                                                                            }
                                                            },
                                             "required":  [
                                                              "file_id"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "list_folder",
                          "description":  "List the contents of a Box folder including files and sub-folders.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "folder_id":  {
                                                                                  "type":  "string",
                                                                                  "description":  "Box folder ID to list contents of (use \u00270\u0027 for root folder)"
                                                                              }
                                                            },
                                             "required":  [
                                                              "folder_id"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "get_document_text",
                          "description":  "Extract and retrieve the text content from a document stored in Box.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "file_id":  {
                                                                                "type":  "string",
                                                                                "description":  "Box file ID of the document to extract text from"
                                                                            }
                                                            },
                                             "required":  [
                                                              "file_id"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "get_document_metadata",
                          "description":  "Retrieve metadata and custom properties associated with a document in Box.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "file_id":  {
                                                                                "type":  "string",
                                                                                "description":  "Box file ID of the document to retrieve metadata for"
                                                                            }
                                                            },
                                             "required":  [
                                                              "file_id"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      }
                  ],
    "runtimes":  [
                     {
                         "type":  "RemoteMCPServer",
                         "spec":  {
                                      "url":  "https://{{MCP_HOST}}/mcp/box"
                                  },
                         "auth":  {
                                      "type":  "OAuthPluginVault"
                                  },
                         "run_for_functions":  [
                                                   "search_documents",
                                                   "get_document",
                                                   "list_folder",
                                                   "get_document_text",
                                                   "get_document_metadata"
                                               ]
                     }
                 ]
}
