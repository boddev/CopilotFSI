{
    "$schema":  "https://aka.ms/json-schemas/copilot/plugin/v2.4/schema.json",
    "schema_version":  "v2.4",
    "name_for_human":  "SEC EDGAR",
    "namespace":  "SECEDGAR",
    "description_for_human":  "Access SEC EDGAR public filings, XBRL financials, and company submissions data.",
    "description_for_model":  "Provides access to the SEC\u0027s EDGAR database of public company filings. Use this plugin to retrieve company metadata and recent filing history via the Submissions API, full-text search across filings via EFTS, retrieve all XBRL-tagged financial facts via CompanyFacts, query time series for specific XBRL concepts via CompanyConcept, and map ticker symbols to CIK numbers. This is a free public data source requiring no authentication.",
    "functions":  [
                      {
                          "name":  "get_submissions",
                          "description":  "Retrieve company metadata and recent SEC filing history (up to 1000 filings) including form types, accession numbers, and filing dates. Also returns company CIK, SIC code, and addresses.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "ticker":  {
                                                                               "type":  "string",
                                                                               "description":  "Stock ticker symbol (e.g., AAPL, MSFT) â€” will be mapped to CIK via company_tickers.json"
                                                                           }
                                                            },
                                             "required":  [
                                                              "ticker"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "search_filings",
                          "description":  "Full-text search across SEC EDGAR filings using EFTS search index. Returns matching filings with excerpts, form types, and dates.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "query":  {
                                                                              "type":  "string",
                                                                              "description":  "Full-text search query to search within filing content"
                                                                          },
                                                                "date_range":  {
                                                                                   "type":  "string",
                                                                                   "description":  "Date range filter: \u0027custom\u0027 to use start_date/end_date, or omit for all dates"
                                                                               },
                                                                "start_date":  {
                                                                                   "type":  "string",
                                                                                   "description":  "Start date in YYYY-MM-DD format (used when date_range is \u0027custom\u0027)"
                                                                               },
                                                                "end_date":  {
                                                                                 "type":  "string",
                                                                                 "description":  "End date in YYYY-MM-DD format (used when date_range is \u0027custom\u0027)"
                                                                             },
                                                                "forms":  {
                                                                              "type":  "string",
                                                                              "description":  "Comma-separated form types to filter (e.g., \u002710-K,10-Q,8-K\u0027)"
                                                                          }
                                                            },
                                             "required":  [
                                                              "query"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "get_company_facts",
                          "description":  "Retrieve all XBRL-tagged financial facts ever filed by a company via SEC EDGAR CompanyFacts API. Returns complete history of standardized financial data points.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "ticker":  {
                                                                               "type":  "string",
                                                                               "description":  "Stock ticker symbol (e.g., AAPL, MSFT) â€” will be mapped to CIK via company_tickers.json"
                                                                           }
                                                            },
                                             "required":  [
                                                              "ticker"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "get_company_concept",
                          "description":  "Retrieve a time series for a specific XBRL financial concept (e.g., Revenue, Assets) across all filings for a company via SEC EDGAR CompanyConcept API.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "ticker":  {
                                                                               "type":  "string",
                                                                               "description":  "Stock ticker symbol (e.g., AAPL, MSFT) â€” will be mapped to CIK via company_tickers.json"
                                                                           },
                                                                "taxonomy":  {
                                                                                 "type":  "string",
                                                                                 "description":  "XBRL taxonomy: \u0027us-gaap\u0027, \u0027ifrs-full\u0027, or \u0027dei\u0027"
                                                                             },
                                                                "tag":  {
                                                                            "type":  "string",
                                                                            "description":  "XBRL concept tag (e.g., \u0027Revenues\u0027, \u0027Assets\u0027, \u0027NetIncomeLoss\u0027)"
                                                                        }
                                                            },
                                             "required":  [
                                                              "ticker",
                                                              "taxonomy",
                                                              "tag"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      },
                      {
                          "name":  "get_ticker_mapping",
                          "description":  "Map stock ticker symbols to SEC CIK numbers using the official SEC company_tickers.json file.",
                          "parameters":  {
                                             "type":  "object",
                                             "properties":  {
                                                                "ticker":  {
                                                                               "type":  "string",
                                                                               "description":  "Stock ticker symbol to look up (e.g., AAPL, MSFT)"
                                                                           }
                                                            },
                                             "required":  [
                                                              "ticker"
                                                          ]
                                         },
                          "capabilities":  {
                                               "security_info":  {
                                                                     "data_handling":  [
                                                                                           "GetPrivateData"
                                                                                       ]
                                                                 }
                                           }
                      }
                  ],
    "runtimes":  [
                     {
                         "type":  "RemoteMCPServer",
                         "spec":  {
                                      "url":  "https://edgar-gc-mcp-a9b0d3djcvbafhex.northcentralus-01.azurewebsites.net/mcp"
                                  },
                         "auth":  {
                                      "type":  "None"
                                  },
                         "run_for_functions":  [
                                                   "get_submissions",
                                                   "search_filings",
                                                   "get_company_facts",
                                                   "get_company_concept",
                                                   "get_ticker_mapping"
                                               ]
                     }
                 ]
}
