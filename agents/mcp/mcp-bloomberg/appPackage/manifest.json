{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/vDevPreview/MicrosoftTeams.schema.json",
  "manifestVersion": "devPreview",
  "id": "${{TEAMS_APP_ID}}",
  "version": "1.0.0",
  "developer": {
    "name": "Financial Services",
    "websiteUrl": "https://example.com",
    "privacyUrl": "https://example.com/privacy",
    "termsOfUseUrl": "https://example.com/terms"
  },
  "name": {
    "short": "Bloomberg Data Connector",
    "full": "Bloomberg Financial Data Connector (BLPAPI)"
  },
  "description": {
    "short": "Provides access to Bloomberg financial data via BLPAPI REST gateway.",
    "full": "Provides access to Bloomberg financial data via BLPAPI REST gateway including real-time market data, reference data, historical prices, and security lookup."
  },
  "icons": { "outline": "outline.png", "color": "color.png" },
  "accentColor": "#0078D4",
  "copilotAgents": {
    "declarativeAgents": [{ "id": "declarativeAgent", "file": "declarativeAgent.json" }]
  }
}
