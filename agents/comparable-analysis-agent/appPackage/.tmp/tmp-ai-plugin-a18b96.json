{
    "$schema": "https://developer.microsoft.com/json-schemas/copilot/plugin/v2.2/schema.json",
    "schema_version": "v2.2",
    "name_for_human": "Alpha Vantage Real-Time Prices",
    "description_for_human": "Access real-time and historical stock prices, forex rates, and treasury yields from Alpha Vantage.",
    "description_for_model": "Use this plugin to get real-time stock quotes, daily and intraday price data, foreign exchange rates, and treasury yield curves from Alpha Vantage. Best for current pricing data and short-term price analysis.",
    "namespace": "alphavantage",
    "functions": [
        {
            "name": "get_quote",
            "description": "Retrieve a real-time stock quote including price, change, volume, and key metrics.",
            "parameters": {
                "type": "object",
                "properties": {
                    "ticker": {
                        "type": "string",
                        "description": "Stock ticker symbol (e.g., AAPL, MSFT)"
                    }
                },
                "required": [
                    "ticker"
                ]
            }
        },
        {
            "name": "get_daily_prices",
            "description": "Retrieve daily OHLCV price data for a stock over a specified date range.",
            "parameters": {
                "type": "object",
                "properties": {
                    "ticker": {
                        "type": "string",
                        "description": "Stock ticker symbol (e.g., AAPL, MSFT)"
                    },
                    "start_date": {
                        "type": "string",
                        "description": "Start date in ISO format (e.g., 2024-01-01)"
                    },
                    "end_date": {
                        "type": "string",
                        "description": "End date in ISO format (e.g., 2024-12-31)"
                    },
                    "adjusted": {
                        "type": "boolean",
                        "description": "Whether to return split/dividend adjusted prices (default: true)"
                    }
                },
                "required": [
                    "ticker"
                ]
            }
        },
        {
            "name": "get_intraday_prices",
            "description": "Retrieve intraday price data at specified intervals.",
            "parameters": {
                "type": "object",
                "properties": {
                    "ticker": {
                        "type": "string",
                        "description": "Stock ticker symbol (e.g., AAPL, MSFT)"
                    },
                    "interval": {
                        "type": "string",
                        "description": "Time interval: 1min, 5min, 15min, 30min, or 60min"
                    },
                    "date": {
                        "type": "string",
                        "description": "Specific trading date in ISO format (e.g., 2024-06-15)"
                    }
                },
                "required": [
                    "ticker"
                ]
            }
        },
        {
            "name": "get_forex_rate",
            "description": "Retrieve real-time or historical foreign exchange rates between currency pairs.",
            "parameters": {
                "type": "object",
                "properties": {
                    "from_currency": {
                        "type": "string",
                        "description": "Source currency code (e.g., USD, EUR, GBP)"
                    },
                    "to_currency": {
                        "type": "string",
                        "description": "Target currency code (e.g., JPY, CHF, CAD)"
                    },
                    "date": {
                        "type": "string",
                        "description": "Specific date for historical rate in ISO format (e.g., 2024-06-15)"
                    }
                },
                "required": [
                    "from_currency",
                    "to_currency"
                ]
            }
        },
        {
            "name": "get_treasury_yield",
            "description": "Retrieve US Treasury yield data for various maturities.",
            "parameters": {
                "type": "object",
                "properties": {
                    "maturity": {
                        "type": "string",
                        "description": "Treasury maturity: 3month, 2year, 5year, 7year, 10year, or 30year"
                    },
                    "date_range": {
                        "type": "string",
                        "description": "Date range for historical yields (e.g., 1Y, 6M, 2023-01-01:2024-01-01)"
                    }
                },
                "required": [
                    "maturity"
                ]
            }
        }
    ],
    "runtimes": [
        {
            "type": "MCP",
            "spec": {
                "url": "https://mcp.alphavantage.co/mcp"
            },
            "auth": {
                "type": "OAuthPluginVault"
            },
            "run_for_functions": [
                "get_quote",
                "get_daily_prices",
                "get_intraday_prices",
                "get_forex_rate",
                "get_treasury_yield"
            ]
        }
    ]
}
